# ─────────────────────────────────────────────────────────────────────────────
# Astra Agents service env (backend). Copy to agents/.env and fill in.
# NEVER commit real keys — agents/.env is git-ignored; only this example is tracked.
# Grouped by integration; leave a value blank until you start wiring that piece.
# ─────────────────────────────────────────────────────────────────────────────

# ── App / server ─────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
PORT=8000
LOG_LEVEL=info
FRONTEND_URL=http://localhost:5173   # used for CORS allow-list

# ── Convex — the shared DB the agents read/write ─────────────────────────────
CONVEX_URL=https://quirky-mallard-785.convex.cloud
# CONVEX_DEPLOY_KEY=            # only for CI/prod deploy scripts, not runtime

# ── OpenAI / GPT-5.6 Sol (reasoning behind Hermes + every sub-agent) ──────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
# OPENAI_BASE_URL=             # only if routing through Hermes/a gateway

# ── Linkup — hospital & cost live search ─────────────────────────────────────
LINKUP_API_KEY=

# ── ElevenLabs — voice output (spoken updates / family notifications) ─────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=           # the voice to speak with (from the ElevenLabs dashboard)
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ── Email — real email scores higher on the rubric. Pick ONE provider. ────────
# Option A — Resend (simplest):
RESEND_API_KEY=
EMAIL_FROM=astra@yourdomain.com
# Option B — plain SMTP (Gmail app password, etc.):
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ── Dodo Payments — live checkout (deposits / co-pays) ───────────────────────
DODO_PAYMENTS_API_KEY=
DODO_WEBHOOK_SECRET=           # verifies incoming payment webhooks
# DODO_ENV=test                # test | live
CHECKOUT_SUCCESS_URL=http://localhost:5173/payment/success
CHECKOUT_CANCEL_URL=http://localhost:5173/payment/cancel

# ── Telegram — Hermes gateway (optional; if users DM a bot) ───────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=

# ── Notes ────────────────────────────────────────────────────────────────────
# • Wispr Flow needs NO key here — it's desktop dictation that types into any
#   field (voice → text happens before your app ever sees it).
# • Cloudflare deploy tokens (CLOUDFLARE_API_TOKEN / ACCOUNT_ID) live in CI or
#   your shell at deploy time, not in this runtime env.
