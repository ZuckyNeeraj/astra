# ─────────────────────────────────────────────────────────────────────────────
# Astra — root env reference (copy to .env.local and fill in; NEVER commit real keys)
#
# Split by where the secret is allowed to live:
#   • VITE_*  → bundled into the browser. ONLY put non-secret, public values here.
#   • server  → Convex env vars + agents/.env. Real API keys go here, never VITE_*.
# ─────────────────────────────────────────────────────────────────────────────

# ── Client-safe (frontend, browser-exposed) ──────────────────────────────────
# Convex deployment URL — printed by `npx convex dev`. Safe to expose.
VITE_CONVEX_URL=

# ── Convex deployment ────────────────────────────────────────────────────────
# Written by `npx convex dev` into .env.local automatically. Do not hand-edit.
CONVEX_DEPLOYMENT=

# ── Server-only secrets (set in Convex dashboard env vars AND/OR agents/.env) ─
# The backend/agents service uses more of these — see agents/.env.example for the
# full grouped reference (voice IDs, email, Dodo webhook, app config, etc.).
#
# GPT-5.6 Sol reasoning behind Hermes + every sub-agent
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
# Hospital / diagnostic-center & cost search
LINKUP_API_KEY=
# Voice output — spoken updates & family notifications
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Real email (patient/family/hospital notifications) — pick a provider
RESEND_API_KEY=
EMAIL_FROM=astra@yourdomain.com
# Deposits, co-pays, cost settlements (live checkout)
DODO_PAYMENTS_API_KEY=
DODO_WEBHOOK_SECRET=
# Hermes gateway (Telegram bot) — if using the gateway
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=

# ── Not env vars ──────────────────────────────────────────────────────────────
# • Wispr Flow — no key; desktop dictation types voice→text into any field.
# • Cloudflare deploy (CLOUDFLARE_API_TOKEN / ACCOUNT_ID) — set at deploy time in
#   CI or your shell, not in app runtime env.
